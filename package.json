{
  "name": "tokenscope",
  "displayName": "TokenScope",
  "description": "Auto-track Claude Code token usage per project. See how many tokens you've spent with Claude Code on each workspace.",
  "version": "0.2.0",
  "publisher": "hooni0918",
  "repository": {
    "type": "git",
    "url": "https://github.com/hooni0918/TokenScope"
  },
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "claude",
    "claude code",
    "token",
    "usage",
    "tracking",
    "LLM",
    "anthropic"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tokenScope.showDashboard",
        "title": "Show Token Dashboard",
        "category": "TokenScope"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tokenscope",
          "title": "TokenScope",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "tokenscope": [
        {
          "id": "tokenScope.usageView",
          "name": "Token Usage"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  }
}
